# ============================================
# SIDDHARTH JAIN PORTFOLIO — ENV CONFIGURATION
# ============================================
# Copy this file to .env.local and fill in values
# cp .env.local.example .env.local

# -----------------------------------------------
# REQUIRED: Groq API Key (FREE)
# Get yours at: https://console.groq.com/keys
# Free tier: very generous limits, no credit card needed
# Model used: llama-3.3-70b-versatile (extremely capable)
# -----------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------
# OPTIONAL: Resend API Key (for contact form emails)
# Get yours at: https://resend.com
# -----------------------------------------------
RESEND_API_KEY=your_resend_api_key_here

# -----------------------------------------------
# Admin password for analytics dashboard
# -----------------------------------------------
ADMIN_PASSWORD=your_admin_password_here
